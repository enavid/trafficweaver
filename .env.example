# ─────────────────────────────────────────────
#  TrafficWeaver – Environment Configuration
# ─────────────────────────────────────────────

# Daily download target in bytes (10 GB default)
# Actual daily target is randomised ±20% around this value
DAILY_TARGET_BYTES=10737418240

# Allowed variance around daily target (0.20 = ±20%)
DAILY_VARIANCE=0.20

# ── File Download List ────────────────────────
# Format: URL|SIZE_IN_BYTES  (one entry per line, separated by newline)
# SIZE is used for scheduling; actual bytes transferred are measured live.
FILE_DOWNLOAD_LIST=https://speed.hetzner.de/100MB.bin|104857600,https://ash-speed.hetzner.com/100MB.bin|104857600

# ── Browsing Site List ────────────────────────
# Plain URLs, one per line. Only the landing page (and a few internal links)
# will be fetched per visit.
BROWSING_SITE_LIST=https://www.wikipedia.org,https://www.github.com,https://www.stackoverflow.com

# IP address of the network interface to use for outbound traffic (leave empty for default)
BIND_IP=

# ── Schedule Weights (must sum to ~1.0) ───────
# Probability weights for each 6-hour window of the day.
# [00-06, 06-12, 12-18, 18-24]
SCHEDULE_WEIGHTS=0.05,0.30,0.35,0.30
# SCHEDULE_WEIGHTS=1.0,1.0,1.0,1.0 # for debug

# ── Download Settings ─────────────────────────
# Maximum simultaneous file downloads
MAX_CONCURRENT_DOWNLOADS=2

# Download speed cap per file in bytes/sec (0 = unlimited)
# Example: 2097152 = 2 MB/s
DOWNLOAD_SPEED_CAP=2097152

# Probability of pausing a download mid-way to simulate human behaviour
DOWNLOAD_PAUSE_PROBABILITY=0.3

# Pause duration range in seconds [min, max]
DOWNLOAD_PAUSE_RANGE=15,120

# ── Browsing Settings ─────────────────────────
# Seconds to wait between page visits [min, max]
BROWSE_DELAY_RANGE=8,75

# Max internal links to follow per site visit (0 = landing page only)
BROWSE_MAX_INTERNAL_LINKS=3

# Use real Chromium browser via Playwright (True) or lightweight HTTP (False)
# Playwright is harder to detect as a bot but requires extra installation.
USE_PLAYWRIGHT=False

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/trafficweaver.log
